# Copy this file to .env and fill in real values for production use.
# Leave MOCK_MODE=true to run the whole stack without any external API keys.

MOCK_MODE=true

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI (embeddings only)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Postgres / pgvector
DATABASE_URL=postgresql+asyncpg://supportops:supportops@localhost:5432/supportops

# Zendesk (sandbox)
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# Monday.com
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Node webhook bridge
WEBHOOK_BRIDGE_PORT=8787
PYTHON_BACKEND_URL=http://localhost:8000
